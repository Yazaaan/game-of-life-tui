# .gitignore-Datei von https://github.com/github/gitignore/blob/main/C.gitignore

# saves-Ordner bis auf das Wilkommensuniversum ausnehmen
saves/*
!saves/welcome.universe
!saves/glider_gun.universe

# Ausführbare Dateien ausnehmen
game_of_life
test_engine
test_savefile

# Prerequisites
*.d

# Object files
*.o
*.ko
*.obj
*.elf

# Linker output
*.ilk
*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# debug information files
*.dwo
